  "SwaggerEndPoints": [
    {
      "Key": "airline",
      "Config": [
        {
          "Name": "Airline API Documentation",
          "Version": "v1",
          "Url": "http://127.0.0.1:5207/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5055",
