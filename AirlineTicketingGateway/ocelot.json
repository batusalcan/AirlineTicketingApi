        "Period": "1d",
        "PeriodTimespan": 86400,
        "Limit": 3
      }
    },
    {
      "DownstreamPathTemplate": "/api/v1/flight/upload",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "127.0.0.1",
          "Port": 5207
        }
      ],
      "UpstreamPathTemplate": "/gateway/v1/flight/upload",
      "UpstreamHttpMethod": ["POST"],
      "SwaggerKey": "airline"
    },
    {
      "DownstreamPathTemplate": "/api/v1/flight",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "127.0.0.1",
          "Port": 5207
        }
      ],
      "UpstreamPathTemplate": "/gateway/v1/flight",
      "UpstreamHttpMethod": ["POST"],
      "SwaggerKey": "airline"
    },
    {
      "DownstreamPathTemplate": "/api/v1/ticket/{everything}",
